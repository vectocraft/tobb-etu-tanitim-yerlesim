/* ═══ KLAVYE KISAYOLLARI ═══ */
document.addEventListener('keydown',e=>{
  // Modal açıkken kısayolları devre dışı bırak
  if(document.getElementById('modal-overlay').classList.contains('open')) return;
  const ctrl=e.ctrlKey||e.metaKey;
  if(ctrl&&e.key==='z'&&!e.shiftKey){ e.preventDefault(); undo(); return; }
  if(ctrl&&(e.key==='y'||(e.key==='z'&&e.shiftKey))){ e.preventDefault(); redo(); return; }
  if(e.key==='Delete'||e.key==='Backspace'){
    if(mode==='select'&&selected.size>0){
      pushUndo();
      [...selected].forEach(id=>{ const i=desks.findIndex(d=>d.id===id); if(i!==-1){desks[i].el.remove();desks.splice(i,1);} });
      selected.clear(); updateAlignButtons();
    }
  }
  if(e.key==='Escape'){ setMode('drag'); }
  if(ctrl&&e.key==='a'){
    e.preventDefault();
    setMode('select');
    desks.forEach(d=>toggleSelect(d.id,d.el,true));
  }
});
</script>
