/* ═══ DRAG ═══ */
function evPos(e){return e.touches?{x:e.touches[0].clientX,y:e.touches[0].clientY}:{x:e.clientX,y:e.clientY};}

function hallDesignCoords(e){
  const r=document.getElementById('hall').getBoundingClientRect();
  const pos=evPos(e);
  return{x:(pos.x-r.left)/scale, y:(pos.y-r.top)/scale};
}

/* --- tekli masa sürükleme (drag modu) --- */
function startDragDesk(e,el){
  dragging={el};dragType='desk';el.classList.add('dragging');
  const pos=evPos(e),r=el.getBoundingClientRect();
  offsetX=(pos.x-r.left)/scale;
  offsetY=(pos.y-r.top)/scale;
  bindDrag();
}

/* --- grup sürükleme (seçim modu) --- */
function startGroupDrag(e){
  dragType='group';
  const {x,y}=hallDesignCoords(e);
  // seçili masaların başlangıç ofsetlerini sakla
  groupStart={mx:x,my:y,origins:{}};
  desks.filter(d=>selected.has(d.id)).forEach(d=>{
    groupStart.origins[d.id]={x:parseInt(d.el.style.left),y:parseInt(d.el.style.top)};
    d.el.classList.add('dragging');
  });
  bindDrag();
}

/* --- kapı sürükleme --- */
function startDragDoor(e,door,el){
  dragging={door,el};dragType='door';el.classList.add('dragging');
  bindDrag();
}

function snapWall(dx,dy){
  const w=HALL_W,h=HALL_H;
  const d={top:dy,bottom:h-dy,left:dx,right:w-dx};
  const wall=Object.entries(d).sort((a,b)=>a[1]-b[1])[0][0];
  const pct=(wall==='top'||wall==='bottom')?Math.max(.05,Math.min(.95,dx/w)):Math.max(.05,Math.min(.95,dy/h));
  return{wall,pct};
}

function bindDrag(){
  document.addEventListener('mousemove',onMove);
  document.addEventListener('mouseup',onUp);
  document.addEventListener('touchmove',onTouchMove,{passive:false});
  document.addEventListener('touchend',onUp);
}

function onMove(e){
  const {x:dx,y:dy}=hallDesignCoords(e);

  if(dragType==='desk'&&dragging){
    dragging.el.style.left=Math.max(0,Math.min(dx-offsetX,HALL_W-DW))+'px';
    dragging.el.style.top =Math.max(0,Math.min(dy-offsetY,HALL_H-DH))+'px';
  }
  else if(dragType==='group'&&groupStart){
    const ddx=dx-groupStart.mx, ddy=dy-groupStart.my;
    desks.filter(d=>selected.has(d.id)).forEach(d=>{
      const o=groupStart.origins[d.id];
      d.el.style.left=Math.max(0,Math.min(o.x+ddx,HALL_W-DW))+'px';
      d.el.style.top =Math.max(0,Math.min(o.y+ddy,HALL_H-DH))+'px';
    });
  }
  else if(dragType==='door'&&dragging){
    const snap=snapWall(dx,dy);
    dragging.door.wall=snap.wall; dragging.door.pct=snap.pct;
    applyDoorPos(dragging.el,dragging.door);
  }
  else if(dragType==='rubber'&&rubber){
    updateRubber(dx,dy);
  }
}
function onTouchMove(e){e.preventDefault();onMove(e);}
function onUp(e){
  const wasDragging = dragType==='desk'||dragType==='group'||dragType==='door';
  if(dragType==='group'){
    desks.forEach(d=>d.el.classList.remove('dragging'));
    groupStart=null;
  }else if(dragType==='rubber'){
    finishRubber();
  }else if(dragging){
    dragging.el.classList.remove('dragging');
    dragging=null;
  }
  if(wasDragging) pushUndo();
  dragType=null;
  document.removeEventListener('mousemove',onMove);
  document.removeEventListener('mouseup',onUp);
  document.removeEventListener('touchmove',onTouchMove);
  document.removeEventListener('touchend',onUp);
}

/* ═══ RUBBER-BAND SEÇİM ═══ */
function startRubber(e){
  const {x,y}=hallDesignCoords(e);
  rubber={sx:x,sy:y};
  dragType='rubber';
  const sr=document.getElementById('sel-rect');
  sr.style.display='block';
  sr.style.left=x+'px'; sr.style.top=y+'px';
  sr.style.width='0'; sr.style.height='0';
  bindDrag();
}
function updateRubber(cx,cy){
  const sr=document.getElementById('sel-rect');
  const x=Math.min(rubber.sx,cx), y=Math.min(rubber.sy,cy);
  const w=Math.abs(cx-rubber.sx), h=Math.abs(cy-rubber.sy);
  sr.style.left=x+'px'; sr.style.top=y+'px';
  sr.style.width=w+'px'; sr.style.height=h+'px';
}
function finishRubber(){
  const sr=document.getElementById('sel-rect');
  const rx=parseInt(sr.style.left),ry=parseInt(sr.style.top);
  const rw=parseInt(sr.style.width),rh=parseInt(sr.style.height);
  sr.style.display='none';
  if(rw<5&&rh<5){rubber=null;return;}
  clearSelection();
  desks.forEach(d=>{
    const dx=parseInt(d.el.style.left),dy=parseInt(d.el.style.top);
    if(dx>=rx&&dy>=ry&&dx+DW<=rx+rw&&dy+DH<=ry+rh){
      toggleSelect(d.id,d.el,true);
    }
  });
  rubber=null;
}

/* ═══ HALL mousedown → rubber band ═══ */
document.getElementById('hall').addEventListener('mousedown',e=>{
  if(mode!=='select')return;
  if(e.target!==document.getElementById('hall'))return; // masaya tıklanmadıysa
  clearSelection();
  startRubber(e);
});

/* ═══ LEGEND ═══ */
function renderLegend(){
  const leg=document.getElementById('legend-bar');
  Object.values(COLORS).forEach(v=>{
    const it=document.createElement('div');it.className='legend-item';
    it.innerHTML=`<div class="legend-dot" style="background:${v.bg}"></div><span>${v.label}</span>`;
    leg.appendChild(it);
  });
  [{bg:'#e31837',label:'Ana Giriş'},{bg:'#00205b',label:'Yan Kapı'}].forEach(v=>{
    const it=document.createElement('div');it.className='legend-item';
    it.innerHTML=`<div class="legend-dot" style="background:${v.bg};border-radius:2px"></div><span>${v.label}</span>`;
    leg.appendChild(it);
  });
  // hizalama kılavuzu
  const guide=document.createElement('div');guide.className='legend-item';
  guide.innerHTML=`<div class="legend-dot" style="background:#f0a800;border-radius:2px"></div><span>Seçili Masa</span>`;
  leg.appendChild(guide);
}

/* ═══ RESET ═══ */
function resetLayout(){
  document.getElementById('hall').innerHTML='<div id="sel-rect"></div>';
  desks=[];doors=[];selected=new Set();
  HALL_W=800;HALL_H=560;
  document.getElementById('sw').value=HALL_W;
  document.getElementById('sh').value=HALL_H;
  document.getElementById('sw-val').textContent=HALL_W;
  document.getElementById('sh-val').textContent=HALL_H;
  reBindHall();
  init(DEFAULT_DESKS,DEFAULT_DOORS);
  applyScale();
  setMode('drag');
}

function reBindHall(){
  document.getElementById('hall').addEventListener('mousedown',e=>{
    if(mode!=='select')return;
    if(e.target!==document.getElementById('hall'))return;
    clearSelection();startRubber(e);
  });
}

